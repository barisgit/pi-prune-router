{
  "name": "pi-prune-router",
  "version": "0.1.0",
  "description": "Provider-agnostic context pruning router/service extension for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "context-pruning",
    "prune",
    "router"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src/**/*.ts",
    "README.md",
    "SPEC.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@sinclair/typebox": "^0.34.41",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test"
  }
}
